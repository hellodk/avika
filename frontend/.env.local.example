# ==================================================================
# Avika NGINX Manager — Local Development Environment
# ==================================================================
# Configs are read from this file when you run the frontend locally.
# Copy to .env.local and adjust:
#
#   cp .env.local.example .env.local
#
# Resolved in code by:
#   - frontend/src/lib/gateway-url.ts  → GATEWAY_HTTP_URL / GATEWAY_URL (server-side API proxy)
#   - frontend/src/lib/grpc-client.ts   → GATEWAY_GRPC_ADDR (agent gRPC)
#   - frontend/src/app/api/config/route.ts → GATEWAY_EXTERNAL_URL / GATEWAY_HTTP_URL (browser WS/HTTP)
#   - next.config.ts                   → NEXT_PUBLIC_BASE_PATH (e.g. /avika)
# ==================================================================

# --- Local UI + same backend as K8s (quick cosmetics testing) ---
# Point the local frontend at the gateway already running in the cluster.
#
# Option A: Port-forward the gateway, then use localhost:
#   kubectl port-forward -n avika svc/avika-gateway 5021:5021 5020:5020
#   GATEWAY_HTTP_URL=http://localhost:5021
#   GATEWAY_GRPC_ADDR=localhost:5020
#   GATEWAY_EXTERNAL_URL=http://localhost:5021
#
# Option B: Use the cluster FQDN / ingress URL (if reachable from your machine):
#   GATEWAY_HTTP_URL=https://avika.example.com
#   GATEWAY_EXTERNAL_URL=https://avika.example.com
#   GATEWAY_GRPC_ADDR=avika-gateway.avika.svc.cluster.local:5020   # only if gRPC reachable
#
# Option C: Use K8s service DNS (when .cluster.local resolves via kube-dns):
#   Same as deploy/helm/avika/values.yaml. See frontend/.env.local (generated from values).
#   GATEWAY_HTTP_URL=http://avika-gateway.avika.svc.cluster.local:5021
#   GATEWAY_EXTERNAL_URL=http://avika-gateway.avika.svc.cluster.local:5021
#   GATEWAY_GRPC_ADDR=avika-gateway.avika.svc.cluster.local:5020
#   NEXT_PUBLIC_BASE_PATH=/avika
# ==================================================================

# --- Backend Mode ---
# Set to false to connect to a real or local Go gateway.
# NEXT_PUBLIC_MOCK_BACKEND=false

# --- Gateway (HTTP) ---
# Used for server-side API proxy (auth, projects, agents, etc.).
# GATEWAY_HTTP_URL and GATEWAY_URL are equivalent; GATEWAY_HTTP_URL wins.
# GATEWAY_HTTP_URL=http://localhost:5021

# --- Gateway (gRPC) ---
# Used for direct agent communication (commands, live logs). Host:port, no scheme.
# GATEWAY_GRPC_ADDR=localhost:5020

# --- Browser-facing gateway (optional) ---
# If set, /api/config returns this for WebSocket/HTTP in the browser (e.g. cluster FQDN).
# GATEWAY_EXTERNAL_URL=http://localhost:5021

# --- Auth ---
# JWT secret shared between frontend and gateway (must match gateway config).
# JWT_SECRET=your-secret-here

# --- Integrations (optional) ---
# NEXT_PUBLIC_GRAFANA_URL=http://localhost:3000
