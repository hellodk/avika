# ==================================================================
# Avika NGINX Manager — Local Development Environment
# ==================================================================
# Copy this file to .env.local and adjust values for your setup.
#
#   cp .env.local.example .env.local
#
# The gateway defaults (localhost:5021 for HTTP, localhost:5020 for gRPC)
# work out-of-the-box when running the gateway locally.
# ==================================================================

# --- Gateway (HTTP) ---
# Used by Next.js API routes to proxy requests to the Go gateway.
# GATEWAY_URL=http://localhost:5021
# GATEWAY_HTTP_URL=http://localhost:5021

# --- Gateway (gRPC) ---
# Used by the gRPC client for direct agent communication.
# GATEWAY_GRPC_ADDR=localhost:5020

# --- Auth ---
# JWT secret shared between frontend and gateway (must match gateway config).
# JWT_SECRET=your-secret-here

# --- Integrations (optional) ---
# NEXT_PUBLIC_GRAFANA_URL=http://localhost:3000
