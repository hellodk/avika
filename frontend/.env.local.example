# Avika Frontend Local Development Settings

# Disable the mock backend to connect to a real or local Gateway
NEXT_PUBLIC_MOCK_BACKEND=false

# Override the Gateway gRPC address (defaults to localhost:5020)
GATEWAY_GRPC_ADDR=localhost:5020

# Override the Gateway HTTP address (defaults to localhost:5021)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:5021
